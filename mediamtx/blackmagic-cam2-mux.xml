<?xml version="1.0" encoding="UTF-8"?>
<!--
  INTERDEPENDENT TV — iPhone Cam 2, publishing direct to Mux Live.

  Architecture: iPhone (Blackmagic Camera app) ──RTMP──▶ Mux Live ──HLS──▶ Mux CDN ──▶ viewers
  No MediaMTX, no OBS, no Mac mini in this path.

  Cam 2 → Mux Live Stream "Z4Gh58Y2..." (created Apr 23 2026)
  Playback ID: Gbr8YKpVoCYSlvLRZZuDwWahJECZg8lmVBZ37d00z00qk

  HOW TO USE: identical to Cam 1's file — see blackmagic-cam1-mux.xml
  for the full instructions and the why-these-settings notes (RTMPS-not-RTMP,
  H.264-not-HEVC, 1080p-not-4K). The only difference between the two
  files is the <key> element (Mux's per-stream credential) and the <name>.

  CAMERA SETTINGS THAT MUST MATCH:
    Settings → Record → Codec      = H.264 (NOT HEVC)
    Settings → Record → Resolution = 1080p (NOT 4K, ideally)
    Camera tab → FPS pill          = 30
-->
<streaming>
    <service customizable-url="false">
        <name>INTERDEPENDENT TV — Cam 2 (Mux)</name>
        <key>06f72770-4159-b078-1e61-31f2c6b62503</key>
        <servers>
            <server>
                <name>Mux Live RTMP</name>
                <url>rtmp://global-live.mux.com:5222/app</url>
            </server>
        </servers>
        <profiles default="Streaming High">
            <profile>
                <name>Streaming High</name>
                <config resolution="2160p" fps="30" codec="H264">
                    <bitrate>6000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="1080p" fps="30" codec="H264">
                    <bitrate>6000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="720p" fps="30" codec="H264">
                    <bitrate>4000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
            </profile>
            <profile>
                <name>Streaming Medium</name>
                <config resolution="2160p" fps="30" codec="H264">
                    <bitrate>3500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="1080p" fps="30" codec="H264">
                    <bitrate>3500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="720p" fps="30" codec="H264">
                    <bitrate>2500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
            </profile>
        </profiles>
    </service>
</streaming>
