<?xml version="1.0" encoding="UTF-8"?>
<!--
  INTERDEPENDENT TV — iPhone Cam 2, publishing direct to Mux Live via SRT.

  Architecture: iPhone (Blackmagic Camera app) ──SRT──▶ Mux Live ──HLS──▶ Mux CDN ──▶ viewers

  See blackmagic-cam1-mux.xml for the full why-SRT-not-RTMP rationale,
  the URL-embedded streamid+passphrase trick we use to bypass the iOS
  app's broken handling of <srt-extensions>, and the import procedure.
  The only difference from cam1 is the streamid (Mux stream key) and
  passphrase (per-stream SRT secret).

  Cam 2 → Mux Live Stream "Z4Gh58Y2..." (created Apr 23 2026)
  Playback ID: Gbr8YKpVoCYSlvLRZZuDwWahJECZg8lmVBZ37d00z00qk
-->
<streaming>
    <service customizable-url="false">
        <name>INTERDEPENDENT TV — Cam 2 (Mux SRT)</name>
        <servers>
            <server>
                <name>Mux Live SRT</name>
                <url>srt://global-live.mux.com:6001?streamid=06f72770-4159-b078-1e61-31f2c6b62503&amp;passphrase=S7KpTBcQs58LMMKqRP5j6bUIUcTw02zT&amp;pkt_size=1316&amp;latency=200000</url>
                <srt-extensions>
                    <stream-id>
                        <item key="copy" value="0"/>
                    </stream-id>
                </srt-extensions>
            </server>
        </servers>
        <profiles default="Streaming High">
            <profile>
                <name>Streaming High</name>
                <config resolution="2160p" fps="30" codec="H264">
                    <bitrate>6000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="1080p" fps="30" codec="H264">
                    <bitrate>6000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="720p" fps="30" codec="H264">
                    <bitrate>4000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
            </profile>
            <profile>
                <name>Streaming Medium</name>
                <config resolution="2160p" fps="30" codec="H264">
                    <bitrate>3500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="1080p" fps="30" codec="H264">
                    <bitrate>3500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="720p" fps="30" codec="H264">
                    <bitrate>2500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
            </profile>
        </profiles>
    </service>
</streaming>
