<?xml version="1.0" encoding="UTF-8"?>
<!--
  INTERDEPENDENT TV — iPhone Cam 1, publishing direct to Mux Live.

  Architecture: iPhone (Blackmagic Camera app) ──RTMP──▶ Mux Live ──HLS──▶ Mux CDN ──▶ viewers
  No MediaMTX, no OBS, no Mac mini in this path.

  Cam 1 → Mux Live Stream "iye00tyq..." (created May 8 2026)
  Playback ID: P3juo8srQDibzTGEy7HzTUUmPVR9RvQmTlIqZj8KzOI

  HOW TO USE:
    1. AirDrop this file to the iPhone you want as Cam 1.
    2. Save to Files on iPhone.
    3. Blackmagic Camera → Settings → Live Stream → Platform
       → Import Stream Settings → pick this file.
    4. Platform → "INTERDEPENDENT TV — Cam 1 (Mux)"
    5. Quality → "Streaming High"
    6. Toggle Live Stream ON, hit record.

  CAMERA SETTINGS THAT MUST MATCH:
    Settings → Record → Codec      = H.264   (NOT HEVC — Mux Live's
                                               RTMP ingest is H.264-only)
    Settings → Record → Resolution = 1080p   (NOT 4K — see below)
    Camera tab → FPS pill          = 30
    Camera tab → Resolution        = 1080p

  WHY NOT 4K: Per the Blackmagic Streaming XML spec, a <config> with
  resolution="1080p" only applies to 1080p source modes (and 720p, 480p,
  etc — anything ≤ 1080p). At 4K source, the streaming engine has no
  matching profile and refuses to start, which surfaces as "Connection
  Failed!" on the device. We've added 2160p (4K) and 720p configs below
  as fallbacks if you keep the device at 4K, but Mux Standard ingest tier
  caps at 1080p — the 4K config still down-encodes to 1080p output.

  WHY PLAIN RTMP, NOT RTMPS: empirically the iPhone Blackmagic Camera
  app fails its TLS handshake against Mux's RTMPS endpoint — surfaces
  as "Connection Failed!" on the device. Plain RTMP on port 5222 works.
  ffmpeg from the Mac mini has the OPPOSITE compatibility (works on
  RTMPS, fails on plain RTMP) but we don't care about ffmpeg — the
  iPhone is the publisher. Trade-off accepted: stream key travels
  unencrypted on port 5222. For a public test broadcast that's fine;
  for production we'd switch publishers (Larix, OBS, ATEM hardware)
  to ones that speak RTMPS reliably.
-->
<streaming>
    <service customizable-url="false">
        <name>INTERDEPENDENT TV — Cam 1 (Mux)</name>
        <key>67171f80-9225-eac2-1746-f2809081ba3d</key>
        <servers>
            <server>
                <name>Mux Live RTMP</name>
                <url>rtmp://global-live.mux.com:5222/app</url>
            </server>
        </servers>
        <profiles default="Streaming High">
            <profile>
                <name>Streaming High</name>
                <config resolution="2160p" fps="30" codec="H264">
                    <bitrate>6000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="1080p" fps="30" codec="H264">
                    <bitrate>6000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="720p" fps="30" codec="H264">
                    <bitrate>4000000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
            </profile>
            <profile>
                <name>Streaming Medium</name>
                <config resolution="2160p" fps="30" codec="H264">
                    <bitrate>3500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="1080p" fps="30" codec="H264">
                    <bitrate>3500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
                <config resolution="720p" fps="30" codec="H264">
                    <bitrate>2500000</bitrate>
                    <audio-bitrate>128000</audio-bitrate>
                </config>
            </profile>
        </profiles>
    </service>
</streaming>
